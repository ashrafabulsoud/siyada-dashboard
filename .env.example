# Appwrite Configuration
# Copy this file to .env.local and fill in your values.
# Find these values in your Appwrite Console → Project Settings.

# The full URL to your self-hosted Appwrite instance (including /v1)
# Example: https://appwrite.yourdomain.com/v1
VITE_APPWRITE_ENDPOINT=https://your-appwrite-domain/v1

# Your Appwrite Project ID
# Find it in: Appwrite Console → Project Settings → Project ID
VITE_APPWRITE_PROJECT_ID=your_project_id

# The Appwrite Database ID
# Find it in: Appwrite Console → Databases → (select your DB) → Database ID
# Default suggested value: siyada_dashboard
VITE_APPWRITE_DATABASE_ID=siyada_dashboard

# The Collection ID within the database above
# Find it in: Appwrite Console → Databases → (select your DB) → Collections → (select) → Collection ID
# Default suggested value: dashboard_data
VITE_APPWRITE_COLLECTION_ID=dashboard_data
